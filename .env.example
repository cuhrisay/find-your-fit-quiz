# Copy this file to .env.local for local development (vercel dev reads it
# automatically). For the deployed version, set these same variables in the
# Vercel dashboard: Project -> Settings -> Environment Variables.
# NEVER commit an actual .env.local file with real keys to git.

# --- Groq ---
# Get a free API key at https://console.groq.com
GROQ_API_KEY=

# --- Airtable ---
# Personal access token: https://airtable.com/create/tokens
# Needs read + write scope on the base you create for this project.
AIRTABLE_API_KEY=
# Found in the base's API docs page, or the base URL itself (starts with "app")
AIRTABLE_BASE_ID=
# Optional - defaults to "Submissions" if not set
AIRTABLE_SUBMISSIONS_TABLE=Submissions

# --- Mailchimp ---
# Account -> Extras -> API keys
MAILCHIMP_API_KEY=
# The part after the dash in your API key, e.g. if your key ends in "-us4",
# this is "us4"
MAILCHIMP_SERVER_PREFIX=
# Audience/list ID: Audience -> Settings -> Audience name and defaults
MAILCHIMP_AUDIENCE_ID=
